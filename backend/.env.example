# ============================================================================
# Ooumph SHG Agentic AI Ecosystem - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the actual values
# DO NOT commit .env to version control
# Generate secret keys with: openssl rand -hex 32

# ============================================================================
# Database Configuration
# ============================================================================
# For development, SQLite is fine. For production, use PostgreSQL.
DATABASE_URL=sqlite:///./ooumph.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ooumph

# ============================================================================
# Redis Configuration (Caching & Rate Limiting)
# ============================================================================
REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:password@localhost:6379/0

# ============================================================================
# OpenAI API Configuration
# ============================================================================
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=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

# OpenAI Models Configuration
OPENAI_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# ============================================================================
# JWT Authentication
# ============================================================================
# Generate a strong secret key for production
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_this_to_a_strong_secret_key_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================================
# Application Configuration
# ============================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================================================
# CORS Configuration
# ============================================================================
# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# ============================================================================
# Mock Data Settings
# ============================================================================
# Set to false when real government APIs are available
USE_MOCK_DATA=true

# ============================================================================
# Government API Keys (STUBS - Not yet integrated)
# ============================================================================
# GeM Portal API (Government e-Marketplace)
GEM_API_KEY=
GEM_API_URL=

# ONDC API (Open Network for Digital Commerce)
ONDC_API_KEY=
ONDC_API_URL=

# eSARAS API (SERP Platform)
ESARAS_API_KEY=
ESARAS_API_URL=

# RTGS AWARE Platform
RTGS_API_KEY=
RTGS_API_URL=

# ============================================================================
# Payment Gateway (Razorpay)
# ============================================================================
# Get credentials from https://razorpay.com
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# For testing, use Razorpay test mode keys

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
# Redis must be configured for distributed rate limiting

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text
# For production, use json format for structured logging

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_WEBSOCKET=true
ENABLE_CACHE=true
CACHE_TTL=3600  # Cache time-to-live in seconds
ENABLE_VOICE_AGENT=true
ENABLE_TRUST_COINS=true
ENABLE_BULK_ORDERING=true
ENABLE_NEGOTIATION=true

# ============================================================================
# File Upload Configuration
# ============================================================================
# Max file size for uploads (in bytes)
MAX_UPLOAD_SIZE=10485760  # 10MB

# Upload directory
UPLOAD_DIR=./uploads

# ============================================================================
# Rate Limiting (Future)
# ============================================================================
# RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# Feature Flags
# ============================================================================
# Enable/disable features
ENABLE_VOICE_AGENT=true
ENABLE_TRUST_COINS=true
ENABLE_BULK_ORDERING=true
ENABLE_NEGOTIATION=true
