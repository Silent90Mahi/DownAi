# ============================================================================
# Ooumph SHG Smart Market Linkage Platform - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the actual values
# DO NOT commit .env to version control
# Generate secret keys with: openssl rand -hex 32

# ============================================================================
# CRITICAL - REQUIRED FOR ALL DEPLOYMENTS
# ============================================================================
# Your OpenAI API key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# JWT Secret Key - Generate with: openssl rand -hex 32
# IMPORTANT: Change this in production!
SECRET_KEY=change_this_to_a_strong_secret_key_in_production

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Environment: development, staging, or production
ENVIRONMENT=development

# Enable debug mode (set to false in production)
DEBUG=true

# Application name and version
APP_NAME=Ooumph SHG Ecosystem
APP_VERSION=1.0.0

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json (recommended for production) or text
LOG_FORMAT=json

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Development (SQLite - default)
DATABASE_URL=sqlite:///./ooumph.db

# Production (PostgreSQL - recommended)
# DATABASE_URL=postgresql+asyncpg://ooumph:password@db:5432/ooumph

# PostgreSQL Docker Settings (used by docker-compose)
POSTGRES_DB=ooumph
POSTGRES_USER=ooumph
POSTGRES_PASSWORD=change_this_password_in_production

# ============================================================================
# REDIS CONFIGURATION (Caching & Rate Limiting)
# ============================================================================
# Local development
REDIS_URL=redis://localhost:6379

# Docker deployment
# REDIS_URL=redis://redis:6379/0

# With authentication
# REDIS_URL=redis://:password@localhost:6379/0

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# JWT Algorithm (HS256 is standard)
ALGORITHM=HS256

# Token expiration time in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Frontend URL for CORS (comma-separated for multiple origins)
# Development
FRONTEND_URL=http://localhost:5173

# Production
# FRONTEND_URL=https://yourdomain.com

# ============================================================================
# OPENAI MODELS CONFIGURATION
# ============================================================================
# Chat model (gpt-4o, gpt-4, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4o

# Speech-to-text model
OPENAI_WHISPER_MODEL=whisper-1

# Text-to-speech model
OPENAI_TTS_MODEL=tts-1

# TTS voice (alloy, echo, fable, onyx, nova, shimmer)
OPENAI_TTS_VOICE=alloy

# ============================================================================
# RATE LIMITING CONFIGURATION
# ============================================================================
# Enable/disable rate limiting
RATE_LIMIT_ENABLED=true

# Maximum requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# ============================================================================
# CACHING CONFIGURATION
# ============================================================================
# Enable/disable caching
ENABLE_CACHE=true

# Cache time-to-live in seconds (3600 = 1 hour)
CACHE_TTL=3600

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable specific features
ENABLE_WEBSOCKET=true
ENABLE_VOICE_AGENT=true
ENABLE_TRUST_COINS=true
ENABLE_BULK_ORDERING=true
ENABLE_NEGOTIATION=true

# Use mock data for government APIs (set to false when real APIs available)
USE_MOCK_DATA=true

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
# Maximum file size for uploads in bytes (10485760 = 10MB)
MAX_UPLOAD_SIZE=10485760

# Upload directory path
UPLOAD_DIR=./uploads

# ============================================================================
# GOVERNMENT API INTEGRATIONS (STUB - Configure when available)
# ============================================================================
# GeM Portal (Government e-Marketplace)
GEM_API_KEY=
GEM_API_URL=

# ONDC (Open Network for Digital Commerce)
ONDC_API_KEY=
ONDC_API_URL=

# eSARAS (SERP Platform)
ESARAS_API_KEY=
ESARAS_API_URL=

# RTGS AWARE Platform
RTGS_API_KEY=
RTGS_API_URL=

# ============================================================================
# PAYMENT GATEWAY - RAZORPAY
# ============================================================================
# Get credentials from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Use test mode keys for development
# Switch to live mode keys for production

# ============================================================================
# VITE FRONTEND CONFIGURATION (prefixed with VITE_)
# ============================================================================
# Backend API URL (used by frontend)
VITE_API_URL=http://localhost:8000

# For Docker deployment
# VITE_API_URL=http://backend:8000

# For production
# VITE_API_URL=https://api.yourdomain.com

# ============================================================================
# MONITORING & OBSERVABILITY (Optional)
# ============================================================================
# Prometheus metrics endpoint (optional)
# PROMETHEUS_ENABLED=true
# PROMETHEUS_PORT=9090

# Sentry error tracking (optional)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ============================================================================
# EMAIL CONFIGURATION (Optional - for notifications)
# ============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@yourdomain.com

# ============================================================================
# SMS CONFIGURATION (Optional - for OTP)
# ============================================================================
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=your_phone_number
